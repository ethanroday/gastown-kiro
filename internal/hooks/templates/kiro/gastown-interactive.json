{
  "name": "gastown",
  "description": "Gas Town interactive agent",
  "tools": ["*"],
  "allowedTools": ["*"],
  "hooks": {
    "agentSpawn": [
      {
        "command": "{{GT_BIN}} prime --hook"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "{{GT_BIN}} mail check --inject"
      }
    ],
    "stop": [
      {
        "command": "{{GT_BIN}} costs record >/dev/null 2>&1 &"
      }
    ]
  }
}
